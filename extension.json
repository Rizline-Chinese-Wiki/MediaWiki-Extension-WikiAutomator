{
	"name": "WikiAutomator",
	"version": "1.2",
	"author": "Kajiekazz and Rizline-Chinese-Wiki Team",
	"url": "https://github.com/Rizline-Chinese-Wiki/MediaWiki-Extension-WikiAutomator",
	"description": "Visual automation tool for MediaWiki",
	"type": "other",
	"requires": {
		"MediaWiki": ">= 1.39.0"
	},
	"AvailableRights": [
		"manage-automation"
	],
	"GroupPermissions": {
		"sysop": {
			"manage-automation": true
		},
		"bot": {
			"manage-automation": true
		},
		"emailconfirmed": {
			"manage-automation": true
		}
	},
	"SpecialPages": {
		"WikiAutomator": "WikiAutomator\\SpecialWikiAutomator"
	},
	"MessagesDirs": {
		"WikiAutomator": [
			"i18n"
		]
	},
	"ExtensionMessagesFiles": {
		"WikiAutomatorAlias": "WikiAutomator.alias.php"
	},
	"ResourceModules": {
		"ext.wikiautomator": {
			"scripts": "ext.wikiautomator.js",
			"styles": "ext.wikiautomator.css",
			"dependencies": [
				"mediawiki.api",
				"mediawiki.ui.button",
				"mediawiki.ui.input"
			],
			"messages": [
				"wikiautomator-empty-steps",
				"wikiautomator-step-header",
				"wikiautomator-step-delete",
				"wikiautomator-step-add",
				"wikiautomator-step-target-type",
				"wikiautomator-step-target-trigger",
				"wikiautomator-step-target-specific",
				"wikiautomator-step-target-search",
				"wikiautomator-step-target-page",
				"wikiautomator-step-target-page-placeholder",
				"wikiautomator-step-action-type",
				"wikiautomator-step-action-append",
				"wikiautomator-step-action-prepend",
				"wikiautomator-step-action-overwrite",
				"wikiautomator-step-action-replace",
				"wikiautomator-step-value",
				"wikiautomator-step-value-placeholder",
				"wikiautomator-step-search-value",
				"wikiautomator-step-search-value-placeholder",
				"wikiautomator-step-replace-value",
				"wikiautomator-step-replace-value-placeholder",
				"wikiautomator-step-regex-flags",
				"wikiautomator-step-move-pages",
				"wikiautomator-step-create-redirect",
				"wikiautomator-step-search-warning",
				"wikiautomator-step-search-ns-label",
				"wikiautomator-step-search-category",
				"wikiautomator-step-search-category-placeholder",
				"wikiautomator-step-search-prefix",
				"wikiautomator-step-search-prefix-placeholder",
				"wikiautomator-step-search-limit",
				"wikiautomator-step-search-limit-placeholder",
				"wikiautomator-step-search-term",
				"wikiautomator-step-search-term-placeholder",
				"wikiautomator-match-mode",
				"wikiautomator-match-mode-literal",
				"wikiautomator-match-mode-wildcard",
				"wikiautomator-match-mode-regex",
				"wikiautomator-regex-flag-i",
				"wikiautomator-regex-flag-m",
				"wikiautomator-regex-flag-U",
				"wikiautomator-confirm-delete-step",
				"wikiautomator-condition-ns-label"
			]
		}
	},
	"ResourceFileModulePaths": {
		"localBasePath": "resources",
		"remoteExtPath": "WikiAutomator/resources"
	},
	"Attributes": {
		"Monolog": {
			"Channels": {
				"WikiAutomator": {
					"description": "WikiAutomator debug logs"
				}
			}
		}
	},
	"ConfigRegistry": {
		"WikiAutomator": "GlobalVarConfig::newInstance"
	},
	"config": {
		"WikiAutomatorForceSync": {
			"value": false,
			"description": "If true, run tasks immediately (synchronously) instead of pushing to job queue. For debugging only."
		},
		"WikiAutomatorTimezone": {
			"value": "Asia/Shanghai",
			"description": "Timezone for scheduled tasks. Default is Asia/Shanghai (Beijing time)."
		}
	},
	"Hooks": {
		"PageSaveComplete": "WikiAutomator\\Hooks::onPageSaveComplete",
		"LoadExtensionSchemaUpdates": "WikiAutomator\\Hooks::onLoadExtensionSchemaUpdates",
		"CategoryAfterPageAdded": "WikiAutomator\\Hooks::onCategoryAfterPageAdded",
		"CategoryAfterPageRemoved": "WikiAutomator\\Hooks::onCategoryAfterPageRemoved",
		"ListDefinedTags": "WikiAutomator\\Hooks::onListDefinedTags",
		"ChangeTagsListActive": "WikiAutomator\\Hooks::onChangeTagsListActive"
	},
	"JobClasses": {
		"WikiAutomatorJob": "WikiAutomator\\AutomationJob"
	},
	"AutoloadNamespaces": {
		"WikiAutomator\\": "src/"
	},
	"manifest_version": 2
}
